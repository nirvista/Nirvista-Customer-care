            "url": { "raw": "{{baseUrl}}/api/auth/admin-signup", "host": ["{{baseUrl}}"], "path": ["api", "auth", "admin-signup"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin User\",\n  \"role\": \"admin\",\n  \"email\": \"admin@nirvista.com\",\n  \"password\": \"Admin@123\",\n  \"confirmPassword\": \"Admin@123\"\n}"
            }
